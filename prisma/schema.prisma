// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FundStatus {
  Fundraising
  Investing
  Closed
}

model Fund {
  id               String       @id @default(uuid()) @db.Uuid
  name             String
  vintage_year     Int
  target_size_usd  Decimal      @db.Decimal(18, 2)
  status           FundStatus
  created_at       DateTime     @default(now())
  investments      Investment[]

  @@map("funds")
}

enum InvestorType {
  Individual
  Institution
  FamilyOffice
}

model Investor {
  id            String       @id @default(uuid()) @db.Uuid
  name          String
  investor_type InvestorType
  email         String       @unique
  created_at    DateTime     @default(now())
  investments   Investment[]

  @@map("investors")
}

model Investment {
  id              String   @id @default(uuid()) @db.Uuid
  investor_id     String   @db.Uuid
  fund_id         String   @db.Uuid
  amount_usd      Decimal  @db.Decimal(18, 2)
  investment_date DateTime @default(now())
  
  investor        Investor @relation(fields: [investor_id], references: [id])
  fund            Fund     @relation(fields: [fund_id], references: [id])

  @@map("investments")
}
